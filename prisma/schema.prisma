datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  AGENT
  ADMIN
}

enum AccountType {
  ROOT
  AGENT
  INDEPENDENT
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum StoreStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum ApplicationStatus {
  PENDING_PAYMENT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum LedgerStatus {
  AVAILABLE
  WITHDRAWN
}

enum OrderStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  REFUNDED
}

enum NetworkType {
  YELLO
  TELECEL
  AT_PREMIUM
}

enum WithdrawalStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PayoutMethod {
  MANUAL_MOMO
  MANUAL_BANK
  PAYSTACK_TRANSFER
}

enum WalletTransactionType {
  TOPUP
  PURCHASE
  REFERRAL_CREDIT
  PAYOUT
}

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  phone        String?
  passwordHash String
  role         Role     @default(USER)
  accountType  AccountType?
  parentUserId String?
  ancestorPath String   @default("root")
  applicationFeePesewas Int @default(0)
  status       UserStatus @default(PENDING)
  createdAt    DateTime @default(now())

  // Relations
  parent             User?             @relation("UserHierarchy", fields: [parentUserId], references: [id])
  childUsers         User[]            @relation("UserHierarchy")
  stores             Store[]
  pricings           UserPricing[]
  applicationsSent   AgentApplication[] @relation("Applicant")
  applicationsReceived AgentApplication[] @relation("ParentUser")
  reviewedApps       AgentApplication[] @relation("Reviewer")
  ledgers            Ledger[]
  withdrawals        Withdrawal[]
  ordersSelling      Order[]           @relation("SellingUser")
  ordersBought       Order[]           @relation("CustomerUser")
  walletTransactions WalletTransaction[]
}

model Store {
  id             String      @id @default(uuid())
  ownerUserId    String
  slug           String      @unique
  name           String
  status         StoreStatus @default(PENDING)
  displayName    String?
  logoUrl        String?
  primaryColor   String      @default("#4F46E5") // default indigo
  supportEmail   String?
  contactPhone   String?
  footerText     String?
  createdAt      DateTime    @default(now())

  // Relations
  owner             User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  applicationsSubmitted AgentApplication[] @relation("ViaStore")
  orders            Order[]
}

model UserPricing {
  id                        String   @id @default(uuid())
  userId                    String
  bundleId                  String
  priceForCustomersPesewas  Int
  priceForSubAgentsPesewas  Int
  updatedAt                 DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bundle Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([userId, bundleId])
}

model AgentApplication {
  id                     String            @id @default(uuid())
  applicantUserId        String
  parentUserId           String?
  viaStoreId             String?
  storeName              String // Bootstrap applicant's storefront name
  applicationFeePesewas  Int
  paymentRef             String?           @unique
  status                 ApplicationStatus @default(PENDING_PAYMENT)
  reviewedByUserId       String?
  reviewedAt             DateTime?
  createdAt              DateTime          @default(now())

  // Relations
  applicant   User    @relation("Applicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  parentUser  User?   @relation("ParentUser", fields: [parentUserId], references: [id])
  viaStore    Store?  @relation("ViaStore", fields: [viaStoreId], references: [id])
  reviewer    User?   @relation("Reviewer", fields: [reviewedByUserId], references: [id])
  ledgers     Ledger[]
}

model Ledger {
  id               String       @id @default(uuid())
  userId           String
  orderId          String?
  applicationId    String?
  tierDepth        Int          @default(0) // 0 = direct selling agent, 1 = parent, etc.
  buyPricePesewas  Int
  sellPricePesewas Int
  amountPesewas    Int          // Profit: sellPrice - buyPrice
  status           LedgerStatus @default(AVAILABLE)
  createdAt        DateTime     @default(now())

  // Relations
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  application AgentApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
}

model Withdrawal {
  id                 String           @id @default(uuid())
  userId             String
  amountPesewas      Int
  ledgerIds          String[]         // Flipped to WITHDRAWN on complete
  status             WithdrawalStatus @default(PENDING)
  payoutMethod       PayoutMethod     @default(MANUAL_MOMO)
  payoutReference    String?
  requestedAt        DateTime         @default(now())
  completedAt        DateTime?
  completedByUserId  String?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id                 String      @id @default(uuid())
  customerUserId     String?
  storeId            String
  sellingUserId      String
  bundleId           String
  recipientPhone     String
  status             OrderStatus @default(PENDING)
  supplierPurchaseId String?
  supplierOrderRef   String?     @unique
  idempotencyKey     String      @unique
  paystackRef        String?     @unique
  amountPaid         Int
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Relations
  customer   User?    @relation("CustomerUser", fields: [customerUserId], references: [id], onDelete: SetNull)
  sellingUser User    @relation("SellingUser", fields: [sellingUserId], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  bundle     Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  ledgers    Ledger[]
}

model Bundle {
  id             String       @id // Unique identifier, can match Supplier product ID
  network        NetworkType
  label          String
  dataAmountGB   Float
  active         Boolean      @default(true)
  userPricings   UserPricing[]
  orders         Order[]
}

model SupplierAccount {
  id                  String   @id @default(uuid())
  balancePesewas      Int      @default(0)
  rateLimitRemaining  Int      @default(60)
  rateLimitResetAt    DateTime @default(now())
  lastSyncedAt        DateTime @default(now())
}

model WalletTransaction {
  id               String                @id @default(uuid())
  userId           String
  type             WalletTransactionType
  amountPesewas    Int
  balanceAfter     Int
  referenceOrderId String?
  createdAt        DateTime              @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
